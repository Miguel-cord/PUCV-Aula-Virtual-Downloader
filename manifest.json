{
  "manifest_version": 3,
  "name": "PUCV Aula Virtual Downloader",
  "version": "1.0.0",
  "description": "Descarga archivos del Aula Virtual PUCV con un solo clic",
  "permissions": [
    "downloads",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://aulavirtual.pucv.cl/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://aulavirtual.pucv.cl/*"],
      "js": ["jszip.min.js", "content_script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
